// AgamaLang Break and Continue Test
// Tests: break and continue in while loops
// NOTE: For-loop codegen has a label overwrite bug (B23), so tests use while only

fn main() {
    // === Break in while loop ===
    let i: int = 0;
    while (i < 10) {
        i = i + 1;
        if (i == 3) {
            break;
        }
    }
    if (i == 3) { println("PASS: break in while"); }

    // === Continue in while loop ===
    let sum: int = 0;
    let j: int = 0;
    while (j < 10) {
        j = j + 1;
        if (j == 5) {
            continue;
        }
        sum = sum + j;
    }
    // sum = 1+2+3+4+6+7+8+9+10 = 50 (skip 5)
    if (sum == 50) { println("PASS: continue in while"); }

    // === Break in while loop ===
    let found: int = 0;
    let k: int = 0;
    while (k < 100) {
        if (k == 7) {
            found = 1;
            break;
        }
        k = k + 1;
    }
    if (found == 1) { println("PASS: break in while (found=7)"); }

    // === Continue in while (even sum) ===
    let even_sum: int = 0;
    let m: int = 0;
    while (m < 10) {
        m = m + 1;
        if (m % 2 == 1) {
            continue;
        }
        even_sum = even_sum + m;
    }
    // even_sum = 2+4+6+8+10 = 30
    if (even_sum == 30) { println("PASS: continue in while (even sum)"); }

    // === Break from nested loop ===
    let outer_hit: int = 0;
    let x: int = 0;
    while (x < 5 && outer_hit == 0) {
        let y: int = 0;
        while (y < 5) {
            if (x == 2 && y == 2) {
                outer_hit = 1;
                break;
            }
            y = y + 1;
        }
        if (outer_hit == 1) {
            break;
        }
        x = x + 1;
    }
    if (outer_hit == 1) { println("PASS: nested break"); }

    println("PASS: all break/continue tests");
}
