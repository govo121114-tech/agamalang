// AgamaLang Lexer Test
// Tests: hex literals, fixed-point numbers, escape sequences, comments,
//        char literals, all token types, identifier edge cases

fn main() {
    // === Integer literals ===
    let dec: int = 42;
    if (dec == 42) { println("PASS: decimal literal"); }

    let hex: int = 0xFF;
    if (hex == 255) { println("PASS: hex literal"); }

    let zero_hex: int = 0x0;
    if (zero_hex == 0) { println("PASS: zero hex literal"); }

    let neg: int = -10;
    if (neg == -10) { println("PASS: negative literal"); }

    let big: int = 1000000;
    if (big == 1000000) { println("PASS: large literal"); }

    // === Char literals ===
    let ca: int = 'a';
    if (ca == 97) { println("PASS: char literal 'a'"); }

    let c0: int = '\0';
    if (c0 == 0) { println("PASS: char null escape"); }

    let cn: int = '\n';
    if (cn == 10) { println("PASS: char newline escape"); }

    let ct: int = '\t';
    if (ct == 9) { println("PASS: char tab escape"); }

    let cr: int = '\\';
    if (cr == 92) { println("PASS: char backslash escape"); }

    let cq: int = '\'';
    if (cq == 39) { println("PASS: char single quote escape"); }

    // === String escape sequences ===
    let s0: int = str_len("hello\nworld");
    // "hello" (5) + \n (1) + "world" (5) = 11
    if (s0 == 11) { println("PASS: string with \\n"); }

    let s1: int = str_len("tab\there");
    if (s1 == 8) { println("PASS: string with \\t"); }

    let s2: int = str_len("quote\"here");
    if (s2 == 10) { println("PASS: string with \\\""); }

    let s3: int = str_len("back\\slash");
    if (s3 == 10) { println("PASS: string with \\\\"); }

    let s4: int = str_len("null\0term");
    if (s4 == 4) { println("PASS: string stops at null"); }

    // === Block and line comments are tested by the fact this file compiles ===
    println("PASS: all lexer tests completed");
}
