// AgamaLang Nested Blocks Test
// Tests: deeply nested if/while/for blocks, variable shadowing
// NOTE: For-loop codegen has label bug (B23), all loops use while

fn main() {
    let result: int = 0;

    // === Deeply nested if ===
    if (1 == 1) {
        if (2 == 2) {
            if (3 == 3) {
                if (4 == 4) {
                    if (5 == 5) {
                        result = 1;
                    }
                }
            }
        }
    }
    if (result == 1) { println("PASS: deeply nested if"); }

    // === Nested while in while ===
    let i: int = 0;
    let sum: int = 0;
    while (i < 3) {
        let j: int = 0;
        while (j < 3) {
            sum = sum + 1;
            j = j + 1;
        }
        i = i + 1;
    }
    if (sum == 9) { println("PASS: nested while loops"); }

    // === Nested while in while (emulating for) ===
    let prod: int = 0;
    let x: int = 0;
    while (x < 3) {
        let y: int = 0;
        while (y < 4) {
            prod = prod + 1;
            y = y + 1;
        }
        x = x + 1;
    }
    if (prod == 12) { println("PASS: nested emulated for loops"); }

    // === Mixed nesting ===
    let count: int = 0;
    let m: int = 0;
    while (m < 2) {
        let n: int = 0;
        while (n < 3) {
            if (count >= 0) {
                count = count + 1;
            }
            n = n + 1;
        }
        m = m + 1;
    }
    if (count == 6) { println("PASS: mixed nesting"); }

    // === Block scoping ===
    let outer: int = 10;
    {
        let inner: int = 20;
        outer = outer + inner;
    }
    // inner is out of scope here
    if (outer == 30) { println("PASS: block scoping"); }

    println("PASS: all nested block tests");
}
