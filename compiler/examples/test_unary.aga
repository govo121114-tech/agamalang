// AgamaLang Unary Operations Test
// Tests: negation, logical not, address-of, pointer deref (single level)
// NOTE: B7 (Deref always loads 8 bytes), B26 (*ptr = val broken in compile_expr_addr)

fn main() {
    // === Negation ===
    let b: int = -10;
    if (b == -10) { println("PASS: negative literal"); }

    let c: int = -(-5);
    if (c == 5) { println("PASS: double negation"); }

    let d: int = -0;
    if (d == 0) { println("PASS: negate zero"); }

    // === Logical not ===
    if (!0) { println("PASS: !false"); }
    if (!!1) { println("PASS: !!true"); }

    // === Pointer read (single deref) ===
    let val: int = 42;
    let ptr: *int = &val;
    let deref: int = *ptr;
    if (deref == 42) { println("PASS: addr-of and single deref"); }

    // === Null check ===
    let np: *int = null;
    if (np == 0) { println("PASS: null pointer"); }

    // NOTE: `*ptr = value` is broken (B26: compile_expr_addr doesn't handle Deref)
    // Skip pointer-write assignment test

    println("PASS: all unary tests");
}
